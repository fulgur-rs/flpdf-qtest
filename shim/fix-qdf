#!/usr/bin/env bash
#
# shim/fix-qdf — delegating adapter for the qpdf-side `fix-qdf` helper,
# backed by `flpdf qdf-fix` (qpdf-fix-qdf-equivalent subcommand).
#
# qpdf-side CLI: `fix-qdf [filename]` — filename omitted reads stdin;
#                output is always written to stdout.
# flpdf-side  : `flpdf qdf-fix <INPUT> <OUTPUT>` — both required, both
#                must be filesystem paths.
#
# This shim adapts the qpdf stdin/stdout contract to flpdf's positional
# I/O by funnelling through temp files when needed, then streaming the
# repaired output back on stdout.
#
# Required env:
#   FLPDF_CLI_BIN  — absolute path to the flpdf-cli binary to delegate to.
# Optional env:
#   FLPDF_QTEST_NORMALIZE  — sed script path applied to stderr (same as shim/qpdf).
#
# Background: prior to flpdf gaining `qdf-fix`, this shim was a fail-loud
# stub (PR #8 / commit 8219223) to keep the host's /usr/bin/fix-qdf from
# producing spurious PASSes. Now that flpdf ships an equivalent, we
# delegate — matching the README "PATH shadowing" guidance.

set -u

if [[ -z "${FLPDF_CLI_BIN:-}" ]]; then
    echo "shim/fix-qdf: FLPDF_CLI_BIN is not set" >&2
    exit 127
fi
if [[ ! -x "${FLPDF_CLI_BIN}" ]]; then
    echo "shim/fix-qdf: FLPDF_CLI_BIN=${FLPDF_CLI_BIN} is not executable" >&2
    exit 127
fi

tmp_in=""
tmp_out="$(mktemp)"
cleanup() { rm -f "${tmp_in}" "${tmp_out}"; }
trap cleanup EXIT

if [[ $# -eq 0 || "${1:-}" = "-" ]]; then
    tmp_in="$(mktemp)"
    cat > "${tmp_in}"
    input="${tmp_in}"
else
    input="$1"
fi

if [[ -n "${FLPDF_QTEST_NORMALIZE:-}" && -r "${FLPDF_QTEST_NORMALIZE}" ]]; then
    "${FLPDF_CLI_BIN}" qdf-fix "${input}" "${tmp_out}" 2> >(sed -f "${FLPDF_QTEST_NORMALIZE}" 1>&2)
else
    "${FLPDF_CLI_BIN}" qdf-fix "${input}" "${tmp_out}"
fi
rc=$?
cat "${tmp_out}"
exit $rc
